meta {
  name: Get Export
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/exports/{{exportId}}
  body: none
  auth: bearer
}

headers {
  Authorization: Bearer {{token}}
}

params:path {
  exportId: ~
}

docs {
  # Get Export
  
  Retrieves export metadata and a presigned URL for download.
  
  **Path Parameters:**
  - `exportId`: UUID of the export
}

