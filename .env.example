# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=scout
DB_PASSWORD=scout
DB_NAME=scout
DB_SSLMODE=disable

# Valkey
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=
VALKEY_DB=0

# API Server
API_PORT=8080
API_ENV=development

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ISSUER=scout

# Object Storage
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=scout-tiles
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_USE_SSL=true

# Search (OpenSearch/Elasticsearch)
SEARCH_ENABLED=false
SEARCH_HOST=localhost
SEARCH_PORT=9200
SEARCH_USER=
SEARCH_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_DYNAMIC_TILES=false
MAX_SEARCH_CANDIDATES=50000
